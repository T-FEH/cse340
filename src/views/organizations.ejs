<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <p>Here are a few of our partner organizations:</p>
    <ul class="org-list">
        <% organizations.forEach((org) => { %>
        <li class="org-card">
            <img class="org-logo" src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo">
            <div class="org-info">
                <strong><a href="/organization/<%= org.organization_id %>"><%= org.name %></a></strong>
                <p><%= org.description %></p>
                <span><%= org.contact_email %></span>
            </div>
        </li>
        <% }) %>
    </ul>

</main>

<%- include('partials/footer') %>
