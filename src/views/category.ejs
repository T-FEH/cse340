<%- include('partials/header') %>

<main>
    <h1><%= categoryDetails.name %></h1>

    <h2>Service Projects</h2>
    <% if (projects.length > 0) { %>
    <ul>
        <% projects.forEach((project) => { %>
        <li><a href="/project/<%= project.service_project_id %>"><%= project.name %></a> - <%= project.description %></li>
        <% }) %>
    </ul>
    <% } else { %>
    <p>This category does not have any service projects yet.</p>
    <% } %>
</main>

<%- include('partials/footer') %>
